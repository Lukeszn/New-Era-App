rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc(userId) {
      return get(/databases/$(database)/documents/users/$(userId));
    }

    function currentUserDoc() {
      return userDoc(request.auth.uid);
    }

    function hasUserDoc() {
      return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function currentRole() {
      return hasUserDoc() ? currentUserDoc().data.role : null;
    }

    function currentCoachId() {
      return hasUserDoc() ? currentUserDoc().data.coachId : null;
    }

    function isClient() {
      return currentRole() == 'client';
    }

    function isCoach() {
      return currentRole() == 'coach';
    }

    match /users/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isCoach());

      allow create: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.role in ['client', 'coach'];

      allow update: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.role == resource.data.role
        && request.resource.data.coachId == resource.data.coachId;

      allow delete: if false;
    }

    match /bookings/{bookingId} {
      allow read: if signedIn() && (
        (isClient() && resource.data.clientId == request.auth.uid) ||
        (isCoach() && resource.data.coach == currentCoachId())
      );

      allow create: if signedIn()
        && isClient()
        && request.resource.data.clientId == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.pricePounds == 30
        && request.resource.data.durationMinutes == 45;

      allow update: if signedIn() && (
        (
          isClient()
          && resource.data.clientId == request.auth.uid
          && request.resource.data.clientId == resource.data.clientId
          && request.resource.data.coach == resource.data.coach
          && request.resource.data.date == resource.data.date
          && request.resource.data.slot == resource.data.slot
          && request.resource.data.slotStart == resource.data.slotStart
          && request.resource.data.status == resource.data.status
        ) || (
          isCoach()
          && resource.data.coach == currentCoachId()
          && request.resource.data.clientId == resource.data.clientId
          && request.resource.data.coach == resource.data.coach
          && request.resource.data.pricePounds == resource.data.pricePounds
          && request.resource.data.durationMinutes == resource.data.durationMinutes
        )
      );

      allow delete: if false;
    }
  }
}